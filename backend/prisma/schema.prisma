datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum AccommodationType {
  PERSONAL
  CORPORATE
  EDUCATION
}

enum InvoiceType {
  INDIVIDUAL
  CORPORATE
}

// 🆕 WHO is the guest?
enum UserType {
  STUDENT // Sabancı student (lisans / yüksek lisans)
  STAFF // Administrative / academic staff
  SPECIAL_GUEST // Özel misafir
  OTHER
}

// (Optional but nice for later menu/role checks)
enum UserRole {
  USER
  ADMIN
  HOTEL_STAFF
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  userType UserType @default(OTHER)
  role     UserRole @default(USER)

  reservations Reservation[]
  blacklist    Blacklist?
}

model Room {
  id          Int        @id @default(autoincrement())
  name        String
  type        String // e.g. "Single", "Double"
  price       Int // per night
  capacity    Int
  description String
  image       String?
  amenities   String // e.g. "Wifi,TV,AC,Coffee"
  status      RoomStatus @default(AVAILABLE)
  createdAt   DateTime   @default(now())

  reservations Reservation[]
}

model Reservation {
  id Int @id @default(autoincrement())

  // relations
  user   User @relation(fields: [userId], references: [id])
  userId Int

  room   Room? @relation(fields: [roomId], references: [id])
  roomId Int?

  checkIn  DateTime
  checkOut DateTime
  guests   Int

  status            ReservationStatus @default(PENDING)
  accommodationType AccommodationType
  eventCode         String?
  invoiceType       InvoiceType
  note              String?           @db.Text

  // 🆕 snapshot of guest type at time of booking
  guestType UserType @default(OTHER)

  createdAt DateTime @default(now())
}

model Blacklist {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  reason    String
  addedAt   DateTime  @default(now())
  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id])
}
