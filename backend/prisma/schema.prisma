generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  name         String?
  createdAt    DateTime      @default(now())
  role         UserRole      @default(USER)
  userType     UserType      @default(OTHER)
  firstName    String?
  lastName     String?
  phone        String?
  blacklist    Blacklist?
  reservations Reservation[]
}

model Room {
  id           Int           @id @default(autoincrement())
  name         String
  type         String
  price        Int
  capacity     Int
  description  String
  image        String?
  amenities    String
  createdAt    DateTime      @default(now())
  status       RoomStatus    @default(AVAILABLE)
  reservations Reservation[]
}

model Reservation {
  id                Int               @id @default(autoincrement())
  userId            Int
  roomId            Int?
  checkIn           DateTime
  checkOut          DateTime
  guests            Int
  createdAt         DateTime          @default(now())
  accommodationType AccommodationType
  eventCode         String?
  invoiceType       InvoiceType
  note              String?
  status            ReservationStatus @default(PENDING)
  guestType         UserType          @default(OTHER)
  checkInTime       String?
  contactEmail      String?
  eventType         String?
  firstName         String?
  freeAccommodation Boolean           @default(false)
  guestList         Json?
  lastName          String?
  nationalId        String?
  phone             String?
  priceType         String?
  taxNumber         String?
  paymentStatus     PaymentStatus     @default(NONE)
  room              Room?             @relation(fields: [roomId], references: [id])
  user              User              @relation(fields: [userId], references: [id])
}

model Blacklist {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  reason    String
  addedAt   DateTime  @default(now())
  expiresAt DateTime?
  user      User      @relation(fields: [userId], references: [id])
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
}

enum PaymentStatus {
  NONE
  PENDING_VERIFICATION
  APPROVED
  REJECTED
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

enum AccommodationType {
  PERSONAL
  CORPORATE
  EDUCATION
}

enum InvoiceType {
  INDIVIDUAL
  CORPORATE
}

enum UserType {
  STUDENT
  STAFF
  SPECIAL_GUEST
  OTHER
}

enum UserRole {
  USER
  ADMIN
  HOTEL_STAFF
}
