datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Existing Booking Statuses
enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
}

// 🆕 NEW: Specific statuses for the Receipt Verification process
enum PaymentStatus {
  NONE                 // No file uploaded yet
  PENDING_VERIFICATION // File uploaded, waiting for Admin to check
  APPROVED             // Admin verified the PDF
  REJECTED             // Admin found an issue with the PDF
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum AccommodationType {
  PERSONAL
  CORPORATE
  EDUCATION
}

enum InvoiceType {
  INDIVIDUAL
  CORPORATE
}

enum UserType {
  STUDENT
  STAFF
  SPECIAL_GUEST
  OTHER
}

enum UserRole {
  USER
  ADMIN
  HOTEL_STAFF
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  firstName String?
  lastName  String?
  phone     String?

  userType UserType @default(OTHER)
  role     UserRole @default(USER)

  reservations Reservation[]
  blacklist    Blacklist?
}

model Room {
  id          Int            @id @default(autoincrement())
  name        String
  type        String
  price       Int
  capacity    Int
  description String
  image       String?
  amenities   String
  status      RoomStatus     @default(AVAILABLE)
  createdAt   DateTime       @default(now())

  reservations Reservation[]
}

model Reservation {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id])
  userId Int

  room   Room? @relation(fields: [roomId], references: [id])
  roomId Int?

  checkIn     DateTime
  checkOut    DateTime
  checkInTime String? 

  guests Int

  // Overall booking status
  status            ReservationStatus @default(PENDING)
  
  // 🆕 The new field to track the PDF receipt specifically
  paymentStatus     PaymentStatus     @default(NONE)

  accommodationType AccommodationType
  eventCode         String?
  invoiceType       InvoiceType

  firstName    String?
  lastName     String?
  phone        String?
  contactEmail String?

  nationalId String?
  taxNumber  String?

  eventType String?
  priceType String?

  freeAccommodation Boolean @default(false)
  guestList         Json?
  note              String? @db.Text
  guestType         UserType @default(OTHER)

  createdAt DateTime @default(now())
}

model Blacklist {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  reason    String
  addedAt   DateTime  @default(now())
  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id])
}